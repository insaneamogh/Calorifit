generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  age           Int
  gender        String   @default("other")
  heightCm      Float
  currentWeight Float
  goalWeight    Float
  activityLevel String   @default("moderately_active")
  goal          String   @default("maintain") // lose / maintain / gain
  dailyCalGoal  Int
  dailyProteinGoal Float @default(150)
  dailyCarbGoal    Float @default(250)
  dailyFatGoal     Float @default(65)
  dailyWaterGoalMl Int   @default(2500)
  streak        Int      @default(0)
  lastActiveDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  foodLogs      FoodLog[]
  waterLogs     WaterLog[]
  weightEntries WeightEntry[]
  exercises     Exercise[]          @relation("UserExercises")
  pantryItems   PantryItem[]        @relation("UserPantry")
  bodyComps     BodyComposition[]   @relation("UserBodyComps")
}

model Food {
  id          String  @id @default(cuid())
  name        String
  brandName   String?
  calories    Float   // per 100g
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float   @default(0)
  sugar       Float   @default(0)
  glycemicIndex Int?  // Estimated or fetched GI (0-100)
  shifaIndex  Int?    // Computed: (cal * GI) / (protein + fiber) per 100g
  isCustom    Boolean @default(false)
  createdBy   String?
  tags        String[] @default([])

  logItems    FoodLogItem[]
  pantryItems PantryItem[]
}

model FoodLog {
  id        String        @id @default(cuid())
  userId    String
  date      DateTime      @db.Date
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     FoodLogItem[]
  createdAt DateTime      @default(now())

  @@unique([userId, date])
}

model FoodLogItem {
  id         String   @id @default(cuid())
  logId      String
  foodId     String
  meal       String   // breakfast / lunch / dinner / snack
  grams      Float
  calories   Float
  protein    Float
  carbs      Float
  fat        Float
  fiber      Float    @default(0)
  gi         Int      @default(0)   // Glycemic Index of this food
  shifaIndex Int      @default(0)   // Item-level Shifa Index
  photoUrl   String?
  aiDetected Boolean  @default(false)
  createdAt  DateTime @default(now())

  log        FoodLog  @relation(fields: [logId], references: [id], onDelete: Cascade)
  food       Food     @relation(fields: [foodId], references: [id])
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  amountMl  Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  weightKg  Float
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation("UserExercises", fields: [userId], references: [id])
  name           String
  category       String   // "chest", "back", "legs", "shoulders", "arms", "cardio", "core"
  sets           Int?
  reps           Int?
  weight         Float?   // kg
  duration       Int?     // minutes
  caloriesBurned Float?
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
}

model PantryItem {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation("UserPantry", fields: [userId], references: [id])
  foodId     String?
  food       Food?     @relation(fields: [foodId], references: [id])
  name       String
  quantity   Float     @default(1)
  unit       String    @default("piece") // piece, g, kg, ml, L, cup
  expiryDate DateTime?
  category   String?   // "protein", "dairy", "grains", "vegetables", "fruits", "snacks", "condiments"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model BodyComposition {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation("UserBodyComps", fields: [userId], references: [id])
  date             DateTime @db.Date
  weightKg         Float
  bmi              Float?
  bodyFatPct       Float?   // Body fat percentage
  fatFreeBodyKg    Float?   // Fat-free body weight
  subcutaneousFat  Float?   // Subcutaneous fat percentage
  visceralFat      Float?   // Visceral fat level (1-59)
  bodyWaterPct     Float?   // Body water percentage
  skeletalMusclePct Float?  // Skeletal muscle percentage
  muscleMassKg     Float?   // Total muscle mass
  boneMassKg       Float?   // Bone mass
  proteinPct       Float?   // Body protein percentage
  bmr              Float?   // Basal Metabolic Rate (kcal)
  metabolicAge     Int?     // Metabolic age
  source           String   @default("manual") // manual, fitindex, apple_health, google_fit, fitbit
  createdAt        DateTime @default(now())

  @@unique([userId, date, source])
}
